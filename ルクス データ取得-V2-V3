## ================================
## ■ ZCLP v2（GP / LOO 完全分離）
## ================================

# ----------------
# GP kernel
# ----------------
def matern32(x1, x2, l, sigma_f):
    x1 = x1[:, None]
    x2 = x2[None, :]
    r = np.abs(x1 - x2)
    return sigma_f**2 * (1 + np.sqrt(3)*r/l) * np.exp(-np.sqrt(3)*r/l)

# ----------------
# GP prediction
# ----------------
def gp_predict(x, y, yerr, x_pred, l, mean_val, sigma_f):

    K = matern32(x, x, l, sigma_f)
    K_noise = K + np.diag(yerr**2)
    K_star = matern32(x_pred, x, l, sigma_f)
    K_ss = matern32(x_pred, x_pred, l, sigma_f)

    L = cholesky(K_noise, lower=True)
    alpha = solve_triangular(L.T, solve_triangular(L, y - mean_val, lower=True))

    mu = mean_val + K_star @ alpha

    v = solve_triangular(L, K_star.T, lower=True)
    var = np.diag(K_ss) - np.sum(v**2, axis=0)

    return mu, np.sqrt(np.maximum(var, 0))

---

## ================================
## ■ LOO評価（完全独立）
## ================================

def loo_score(x, y, yerr, l, mean_val, sigma_f):

    pulls = []

    for i in range(len(x)):

        mask = np.ones(len(x), dtype=bool)
        mask[i] = False

        mu, sig = gp_predict(
            x[mask], y[mask], yerr[mask],
            x[i:i+1], l, mean_val, sigma_f
        )

        pulls.append((mu[0] - y[i]) / sig[0])

    return np.array(pulls)

