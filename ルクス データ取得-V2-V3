## ================================
## ■ v2実行
## ================================

mean_val = np.mean(g_all)
sigma_f = 0.5

l_scan = np.logspace(-1.3, 0.3, 25)
valid_ls = []

for l in l_scan:
    mu, sig = gp_predict(x_all, g_all, sig_all, x_all, l, mean_val, sigma_f)
    chi2 = np.mean(((mu - g_all)/sig)**2)

    if 0.5 <= chi2 <= 2.0:
        valid_ls.append(l)

print("有効ℓ数:", len(valid_ls))

if len(valid_ls) > 0:

    l_mid = valid_ls[len(valid_ls)//2]
    pulls = loo_score(x_all, g_all, sig_all, l_mid, mean_val, sigma_f)

    print("LOO max|pull| =", np.max(np.abs(pulls)))
    print("LOO mean =", np.mean(pulls))

else:
    print("GP不安定（射影不一致の可能性）")

