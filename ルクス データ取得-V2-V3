## ================================
## ■ 実データ取得（DESI + CC）
## ================================

import numpy as np
from scipy.linalg import cholesky, solve_triangular

# ----------------
# DESI BAO
# ----------------
z_desi = np.array([0.510, 0.706, 0.934, 1.321, 1.484])
g_desi = np.array([0.9549, 0.8670, 1.0283, 1.2767, 1.3747])
sig_desi = np.array([0.15]*5)

# ----------------
# DR1 → H(z) → g(z)
# ----------------
z_dr1 = np.array([0.38, 0.51, 0.70, 0.85, 1.10])

H_dr1 = np.array([81.5, 90.2, 98.8, 110.1, 130.0])
sigH_dr1 = np.array([1.9, 2.1, 2.5, 3.0, 4.0])

H0 = 70.0

g_dr1 = H_dr1 / (H0 * (1 + z_dr1))
sig_dr1 = sigH_dr1 / (H0 * (1 + z_dr1))

# ----------------
# CC（外部H(z)）
# ----------------
z_cc = np.array([
    0.07, 0.12, 0.20, 0.28, 0.35,
    0.40, 0.48, 0.60, 0.73, 0.88,
    1.04, 1.30, 1.43, 1.53, 1.75
])

H_cc = np.array([
    69.0, 68.6, 72.9, 88.8, 82.7,
    95.0, 97.0, 87.9, 97.3, 90.0,
    154.0, 168.0, 177.0, 140.0, 202.0
])

sigma_H_cc = np.array([
    19.6, 26.2, 29.6, 36.6, 8.4,
    17.0, 62.0, 6.1, 7.0, 40.0,
    20.0, 17.0, 18.0, 14.0, 40.0
])

mask = sigma_H_cc < 40
z_cc = z_cc[mask]
H_cc = H_cc[mask]
sigma_H_cc = sigma_H_cc[mask]

# H→g
def H_to_g(H, z):
    return H / (H0 * (1 + z))

g_cc = H_to_g(H_cc, z_cc)
sig_cc = np.maximum(sigma_H_cc / (H0 * (1 + z_cc)), 0.10)

# ----------------
# 統合データ
# ----------------
z_all = np.concatenate([z_desi, z_dr1, z_cc])
g_all = np.concatenate([g_desi, g_dr1, g_cc])
sig_all = np.concatenate([sig_desi, sig_dr1, sig_cc])

x_all = np.log(1 + z_all)

print("総データ数:", len(z_all))

